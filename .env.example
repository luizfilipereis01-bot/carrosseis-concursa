# ── Anthropic (obrigatório) ─────────────────────────────────────────────────
# Gere em: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Canva Connect API (necessário para editar o design automaticamente) ──────
# Guia de setup: https://www.canva.dev/docs/connect/authentication/
#
# 1. Crie um app em https://www.canva.com/developers/
# 2. Defina o Redirect URI como http://localhost:8000/auth/callback
# 3. Copie o Client ID e o Client Secret abaixo
# 4. Acesse http://localhost:8000/auth/login para autenticar — o token é salvo automaticamente

CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=

# Preenchidos automaticamente após o login OAuth (não edite manualmente)
CANVA_ACCESS_TOKEN=
CANVA_REFRESH_TOKEN=
CANVA_TOKEN_EXPIRES_AT=

# URL base do app (ajuste se rodar em produção)
APP_HOST=http://localhost:8000
