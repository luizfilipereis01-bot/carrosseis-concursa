{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 60,
      "includeFiles": "backend/**,frontend/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*",  "destination": "/api/index.py" },
    { "source": "/auth/:path*", "destination": "/api/index.py" },
    { "source": "/(.*)",        "destination": "/api/index.py" }
  ]
}
